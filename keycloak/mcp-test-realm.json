        "composite": false,
        "clientRole": false,
        "containerId": "mcp-test"
      },
      {
        "name": "api-access",
        "description": "Role for API access",
        "composite": false,
        "clientRole": false,
        "containerId": "mcp-test"
      },
      {
        "name": "premium-user",
        "composite": true,
        "clientRole": false,
        "containerId": "mcp-test",
        "composites": {
          "realm": [
            "user",
            "api-access"
          ]
        }
      }
    ],
    "client": {
      "mcp-test-app": [
        {
          "name": "app-admin",
          "clientRole": true,
          "containerId": "mcp-test-app"
        },
        {
          "name": "app-user",
          "clientRole": true,
          "containerId": "mcp-test-app"
        },
        {
          "name": "app-viewer",
          "clientRole": true,
          "containerId": "mcp-test-app"
        }
      ],
      "mcp-api-service": [
        {
          "name": "service-read",
          "clientRole": true,
          "containerId": "mcp-api-service"
        },
        {
          "name": "service-write",
          "clientRole": true,
          "containerId": "mcp-api-service"
        }
      ]
    }
  },
