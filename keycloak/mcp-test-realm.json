  "defaultLocale": "en",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrator role with full access",
        "composite": false,
        "clientRole": false,
        "containerId": "mcp-test"
      },
      {
        "name": "manager",
        "description": "Manager role with limited admin access",
        "composite": false,
        "clientRole": false,
        "containerId": "mcp-test"
