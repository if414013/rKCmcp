# ==============================================================================
# Keycloak MCP Server Configuration
# ==============================================================================
# Copy this file to .env and update the values for your environment
# ==============================================================================

# ==============================================================================
# REQUIRED CONFIGURATION
# ==============================================================================

# Keycloak server base URL
# This is the URL of your Keycloak server instance
# Example: http://localhost:8080 or https://keycloak.example.com
KEYCLOAK_URL=http://localhost:8080

# ==============================================================================
# OPTIONAL CONFIGURATION (with defaults)
# ==============================================================================

# Keycloak realm name
# The Keycloak realm to authenticate against
# Default: master
# Example: mcp-test or my-realm
KEYCLOAK_REALM=master

# MCP Server port
# The port the MCP server will listen on
# Default: 3000
# Range: 0-65535
MCP_PORT=3000

# Logging level
# Controls the verbosity of application logs
# Default: info
# Valid values: trace, debug, info, warn, error
LOG_LEVEL=info

# JWKS cache TTL (Time To Live)
# How long to cache JWKS (JSON Web Key Set) from Keycloak, in seconds
# Default: 3600 (1 hour)
# Smaller values = more frequent requests to Keycloak
# Larger values = better performance but stale keys longer
JWKS_CACHE_TTL=3600

# ==============================================================================
# Keycloak Admin Credentials (for setup/testing)
# ==============================================================================

# Keycloak admin username
KEYCLOAK_ADMIN=admin

# Keycloak admin password
KEYCLOAK_ADMIN_PASSWORD=admin

# ==============================================================================
# Vector Database Configuration (Milvus)
# ==============================================================================

# Milvus host
# Default: localhost (use 'milvus' when running in Docker Compose)
MILVUS_HOST=localhost

# Milvus port
# Default: 19530
MILVUS_PORT=19530

# Milvus collection for documentation vectors
MILVUS_COLLECTION_DOCS=keycloak_docs

# Milvus collection for source code vectors
MILVUS_COLLECTION_CODE=keycloak_code

# MinIO credentials for Milvus storage
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ==============================================================================
# Embedding Configuration
# ==============================================================================

# Embedding model name
# For OpenAI: text-embedding-3-small, text-embedding-3-large
# For local: all-MiniLM-L6-v2 (uses simple hash-based fallback)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Embedding dimension
# Must match the model's output dimension
# text-embedding-3-small: 1536
# all-MiniLM-L6-v2: 384
EMBEDDING_DIMENSION=384

# OpenAI API Key (optional)
# Required only if using OpenAI embedding models
# Leave empty to use local hash-based embeddings
OPENAI_API_KEY=

# ==============================================================================
# Indexer Configuration
# ==============================================================================

# Keycloak documentation URLs to index (comma-separated)
KEYCLOAK_DOCS_URLS=https://www.keycloak.org/docs/latest/server_admin/index.html,https://www.keycloak.org/docs/latest/server_development/index.html,https://www.keycloak.org/docs/latest/authorization_services/index.html,https://www.keycloak.org/docs/latest/upgrading/index.html

# Keycloak repository tag to index
KEYCLOAK_REPO_TAG=26.0.5

# ==============================================================================
# Host Configuration (optional, for reference)
# ==============================================================================

# Keycloak host (used for connecting to Keycloak during setup)
KEYCLOAK_HOST=localhost

# Keycloak port (used for connecting to Keycloak during setup)
KEYCLOAK_PORT=8080

# ==============================================================================
# Client Configuration (optional, for reference)
# ==============================================================================

# Keycloak OAuth 2.1 client ID
KEYCLOAK_CLIENT_ID=mcp-server

# Keycloak OAuth 2.1 client secret
# NOTE: In production, use a secure secret management system
KEYCLOAK_CLIENT_SECRET=<generated-secret>

# OAuth 2.1 token endpoint
OAUTH_TOKEN_ENDPOINT=http://localhost:8080/realms/mcp-test/protocol/openid-connect/token

# OAuth 2.1 authorization endpoint
OAUTH_AUTHORIZE_ENDPOINT=http://localhost:8080/realms/mcp-test/protocol/openid-connect/auth

# ==============================================================================
# MCP Server Configuration (optional, for reference)
# ==============================================================================

# MCP server host
MCP_SERVER_HOST=localhost

# Client scopes required by MCP
MCP_SCOPES=mcp:tools mcp:resources mcp:prompts openid profile email offline_access
